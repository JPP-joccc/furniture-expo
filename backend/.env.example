# ========== 开发环境示例（复制为 .env 后修改）==========
DEBUG=true
SECRET_KEY=dev-only-insecure-key-change-me
ALLOW_LAN_ACCESS=true
ENABLE_API_DOCS=true
ALLOW_DEMO_SEED=true
MERCHANT_INVITE_CODE=dev-merchant-invite
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========== 生产环境必填 ==========
# DEBUG=false
# SECRET_KEY=请用 openssl rand -hex 32 生成随机密钥
# ALLOW_LAN_ACCESS=false
# ENABLE_API_DOCS=false
# ALLOW_DEMO_SEED=false
# MERCHANT_INVITE_CODE=你的商家邀请码（只告知入驻商家）
# CORS_ORIGINS=https://www.你的域名.com
# DATABASE_URL=postgresql://user:pass@host:5432/furniture
